{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"permissions": {
		"allow": [
			"Read(**)",
			"Write(**)",
			"Edit(**)",
			"Bash(./build_git_bash.sh *)",
			"Bash(ls *)",
			"Bash(ls)",
			"Bash(cp *)",
			"Bash(mv *)",
			"Bash(mkdir *)",
			"Bash(cat *)",
			"Bash(git add *)",
			"Bash(git commit *)",
			"Bash(git status)",
			"Bash(git diff *)",
			"Bash(git log *)",
            "Bash(sed *)"
		],
		"deny": [
			"Bash(curl *)",
			"Bash(wget *)",
			"Bash(ssh *)",
			"Bash(scp *)",
			"Bash(ftp *)",
			"Bash(rm *)",
			"Bash(del *)",
			"Bash(rd *)",
			"Bash(rmdir *)",
			"Bash(reg *)",
			"Bash(regedit *)",
			"Bash(net *)",
			"Bash(netsh *)",
			"Bash(powershell *)",
			"Bash(pwsh *)",
			"Bash(wmic *)",
			"Bash(taskkill *)",
			"Bash(sc *)",
			"Bash(bcdedit *)"
		]
	}
}
